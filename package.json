{
  "name": "mkjs-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Workspace root for mk.js CI checks",
  "scripts": {
    "lint": "eslint server/**/*.js game/src/**/*.js",
    "build": "npm run build:server && npm run build:game",
    "build:server": "node --check server/server.js && node --check server/games.js && node --check server/db.js && node --check server/input.js",
    "build:game": "node --check game/src/mk.js && node --check game/src/movement.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "devDependencies": {
    "eslint": "^9.29.0",
    "jest": "^29.6.1",
    "fast-check": "^3.3.0"
  },
  "jest": {
    "coverageDirectory": "coverage-sonar",
    "coverageReporters": [
      "text",
      "lcov",
      "clover"
    ],
    "collectCoverageFrom": [
      "server/games.js",
      "server/input.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 85,
        "functions": 90,
        "lines": 95,
        "statements": 95
      }
    }
  }
}
